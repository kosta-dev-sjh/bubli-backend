@baseUrl = http://localhost:8080
@accessToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIyMjIyMjIyMi0yMjIyLTIyMjItMjIyMi0yMjIyMjIyMjIyMjIiLCJpYXQiOjE3ODI4NzI4MDAsImV4cCI6MTc4Mjk1OTIwMH0.WeOj_uPjyAXWYFY74bvCmK0Dx-HSbaiJby9X5K2X9Eo
@resourceId = replace-with-resource-id
@commentId = replace-with-comment-id
@roomId = replace-with-room-id

### 저장 용량 조회
GET {{baseUrl}}/api/storage/usage
Authorization: Bearer {{accessToken}}

### 개인 자료 목록
GET {{baseUrl}}/api/resources?scope=personal
Authorization: Bearer {{accessToken}}

### 개인 자료 메타데이터 생성
POST {{baseUrl}}/api/resources
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "계약서 초안",
  "kind": "FILE",
  "visibility": "PERSONAL"
}

### 개인 자료 파일 업로드
POST {{baseUrl}}/api/resources
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=uploadBoundary

--uploadBoundary
Content-Disposition: form-data; name="title"

계약서 원본
--uploadBoundary
Content-Disposition: form-data; name="kind"

FILE
--uploadBoundary
Content-Disposition: form-data; name="visibility"

PERSONAL
--uploadBoundary
Content-Disposition: form-data; name="file"; filename="contract.pdf"
Content-Type: application/pdf

< ./sample-files/contract.pdf
--uploadBoundary--

### 프로젝트룸 자료 목록
GET {{baseUrl}}/api/project-rooms/{{roomId}}/resources
Authorization: Bearer {{accessToken}}

### 프로젝트룸 자료 메타데이터 생성
POST {{baseUrl}}/api/resources
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "회의록",
  "kind": "FILE",
  "visibility": "ROOM_SHARED",
  "roomId": "{{roomId}}"
}

### 프로젝트룸 자료 파일 업로드
POST {{baseUrl}}/api/resources
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=uploadBoundary

--uploadBoundary
Content-Disposition: form-data; name="title"

회의록 원본
--uploadBoundary
Content-Disposition: form-data; name="kind"

FILE
--uploadBoundary
Content-Disposition: form-data; name="visibility"

ROOM_SHARED
--uploadBoundary
Content-Disposition: form-data; name="roomId"

{{roomId}}
--uploadBoundary
Content-Disposition: form-data; name="file"; filename="meeting.pdf"
Content-Type: application/pdf

< ./sample-files/meeting.pdf
--uploadBoundary--

### 자료 상세
GET {{baseUrl}}/api/resources/{{resourceId}}
Authorization: Bearer {{accessToken}}

### 자료 메타데이터 수정
PATCH {{baseUrl}}/api/resources/{{resourceId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "계약서 초안 v2"
}

### 자료 삭제
DELETE {{baseUrl}}/api/resources/{{resourceId}}
Authorization: Bearer {{accessToken}}

### 자료 댓글 목록
GET {{baseUrl}}/api/resources/{{resourceId}}/comments?page=0&size=20
Authorization: Bearer {{accessToken}}

### 자료 버전 목록
GET {{baseUrl}}/api/resources/{{resourceId}}/versions?page=0&size=20
Authorization: Bearer {{accessToken}}

### 자료 요약
GET {{baseUrl}}/api/resources/{{resourceId}}/summary
Authorization: Bearer {{accessToken}}

### 관련 자료 목록
GET {{baseUrl}}/api/resources/{{resourceId}}/related?page=0&size=20
Authorization: Bearer {{accessToken}}

### 자료 다운로드 URL 발급
GET {{baseUrl}}/api/resources/{{resourceId}}/download-url
Authorization: Bearer {{accessToken}}

### 자료 버전 등록
POST {{baseUrl}}/api/resources/{{resourceId}}/versions
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "storageKey": "resources/{{resourceId}}/v1.pdf",
  "originalName": "계약서.pdf",
  "mimeType": "application/pdf",
  "sizeBytes": 1024,
  "checksum": null
}

### 자료 댓글 작성
POST {{baseUrl}}/api/resources/{{resourceId}}/comments
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "parentId": null,
  "body": "확인했습니다."
}

### 자료 댓글 수정
PATCH {{baseUrl}}/api/resource-comments/{{commentId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "body": "확인했습니다. 수정합니다."
}

### 자료 댓글 삭제
DELETE {{baseUrl}}/api/resource-comments/{{commentId}}
Authorization: Bearer {{accessToken}}
