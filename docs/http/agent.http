@baseUrl = http://localhost:8080
@accessToken = replace-with-local-access-token
@agentJobId = replace-with-agent-job-id
@suggestionId = replace-with-agent-suggestion-id
@resourceId = replace-with-resource-id
@relatedResourceId = replace-with-related-resource-id
@roomId = replace-with-room-id
@summaryDate = 2026-07-01
@generatedDocumentId = replace-with-generated-document-id

### Create resource analysis job
POST {{baseUrl}}/api/ai/analyze-resource
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "resourceId": "{{resourceId}}"
}

### Create requirements generation job
POST {{baseUrl}}/api/ai/generate-requirements
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "roomId": "{{roomId}}"
}

### Create task generation job
POST {{baseUrl}}/api/ai/generate-tasks
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "roomId": "{{roomId}}"
}

### Create WBS generation job
POST {{baseUrl}}/api/ai/generate-wbs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "roomId": "{{roomId}}"
}

### Create clarification question generation job
POST {{baseUrl}}/api/ai/generate-questions
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "roomId": "{{roomId}}"
}

### Create contract document review job
POST {{baseUrl}}/api/ai/review-contract-documents
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "roomId": "{{roomId}}"
}

### Create daily summary job
POST {{baseUrl}}/api/ai/summarize-day
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "summaryDate": "{{summaryDate}}",
  "timezone": "Asia/Seoul"
}

### Create document draft job
POST {{baseUrl}}/api/ai/draft-document
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "roomId": "{{roomId}}",
  "documentType": "MEETING_NOTE",
  "sourceResourceIds": [
    "{{resourceId}}",
    "{{relatedResourceId}}"
  ],
  "instruction": "Draft a concise meeting note with decisions and action items."
}

### Search personal resources
POST {{baseUrl}}/api/ai/search-resource
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "scope": "PERSONAL",
  "query": "meeting decisions",
  "topK": 5
}

### Search room-shared resources
POST {{baseUrl}}/api/ai/search-resource
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "scope": "ROOM_SHARED",
  "roomId": "{{roomId}}",
  "query": "project requirements",
  "topK": 5
}

### Get agent job status
GET {{baseUrl}}/api/agent-jobs/{{agentJobId}}
Authorization: Bearer {{accessToken}}

### Get agent job events
GET {{baseUrl}}/api/agent-jobs/{{agentJobId}}/events?page=0&size=20
Authorization: Bearer {{accessToken}}

### Get resource AI document
GET {{baseUrl}}/api/resources/{{resourceId}}/ai-document
Authorization: Bearer {{accessToken}}

### List room AI documents
GET {{baseUrl}}/api/project-rooms/{{roomId}}/ai-documents?status=READY&page=0&size=20
Authorization: Bearer {{accessToken}}

### List related resources
GET {{baseUrl}}/api/resources/{{resourceId}}/related
Authorization: Bearer {{accessToken}}

### List daily summaries
GET {{baseUrl}}/api/daily-summaries?from={{summaryDate}}&to={{summaryDate}}
Authorization: Bearer {{accessToken}}

### List personal agent suggestions
GET {{baseUrl}}/api/agent/suggestions?status=DRAFT&suggestionType=DAILY_SUMMARY
Authorization: Bearer {{accessToken}}

### List room agent suggestions
GET {{baseUrl}}/api/project-rooms/{{roomId}}/agent/suggestions?status=DRAFT
Authorization: Bearer {{accessToken}}

### List room confirmation items
GET {{baseUrl}}/api/project-rooms/{{roomId}}/agent/confirmation-items?status=DRAFT
Authorization: Bearer {{accessToken}}

### Edit agent suggestion before applying it
PATCH {{baseUrl}}/api/agent/suggestions/{{suggestionId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "action": "EDIT",
  "editedContent": {
    "title": "Edited suggestion title",
    "memo": "Edited content to apply after approval."
  }
}

### Approve and apply agent suggestion
PATCH {{baseUrl}}/api/agent/suggestions/{{suggestionId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "action": "APPROVE"
}

### List personal generated documents
GET {{baseUrl}}/api/generated-documents?page=0&size=20
Authorization: Bearer {{accessToken}}

### List room generated documents
GET {{baseUrl}}/api/project-rooms/{{roomId}}/generated-documents?page=0&size=20
Authorization: Bearer {{accessToken}}

### Get generated document
GET {{baseUrl}}/api/generated-documents/{{generatedDocumentId}}
Authorization: Bearer {{accessToken}}

### List generated tasks
GET {{baseUrl}}/api/project-rooms/{{roomId}}/tasks?page=0&size=20
Authorization: Bearer {{accessToken}}

### List generated WBS items
GET {{baseUrl}}/api/project-rooms/{{roomId}}/wbs-items?page=0&size=20
Authorization: Bearer {{accessToken}}

### List generated schedules
GET {{baseUrl}}/api/schedules?roomId={{roomId}}&page=0&size=20
Authorization: Bearer {{accessToken}}
