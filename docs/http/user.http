@baseUrl = http://localhost:8080
@accessToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiI5MWM3ZDJmMC0zZjFkLTQxZWMtYTUzZi1mYTg4MWI4NjM3NjYiLCJpYXQiOjE3ODI4NzI4MDAsImV4cCI6MTc4Mjk1OTIwMH0.t_OADNgnqShxxZay9EHmEuUklZ71gx5Wg0gRviglwGM

### 내 프로필 조회
GET {{baseUrl}}/api/me
Authorization: Bearer {{accessToken}}

### 내 프로필 수정
PATCH {{baseUrl}}/api/me
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "마렌",
  "avatarUrl": "https://cdn.example/avatar.png",
  "locale": "ko-KR",
  "timezone": "Asia/Seoul"
}

### 내가 참여 중인 프로젝트룸 목록
GET {{baseUrl}}/api/me/project-rooms?page=0&size=20
Authorization: Bearer {{accessToken}}

### 내 사용자 설정 조회
GET {{baseUrl}}/api/me/preferences
Authorization: Bearer {{accessToken}}

### 내 사용자 설정 수정
PATCH {{baseUrl}}/api/me/preferences
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "theme": "LIGHT",
  "defaultHomeType": "PROJECT_ROOM",
  "defaultProjectRoomId": "replace-with-room-id"
}

### 내 알림 설정 조회
GET {{baseUrl}}/api/me/notification-preferences
Authorization: Bearer {{accessToken}}

### 내 알림 설정 수정
PATCH {{baseUrl}}/api/me/notification-preferences
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "items": [
    {
      "notificationType": "MESSAGE",
      "enabled": true
    },
    {
      "notificationType": "COMMENT",
      "enabled": true
    },
    {
      "notificationType": "RESOURCE",
      "enabled": true
    },
    {
      "notificationType": "AGENT",
      "enabled": true
    },
    {
      "notificationType": "STORAGE",
      "enabled": false
    }
  ]
}

### 내 개인정보 동의 상태 조회
GET {{baseUrl}}/api/me/privacy-consents
Authorization: Bearer {{accessToken}}

### 내 개인정보 동의 상태 수정
PATCH {{baseUrl}}/api/me/privacy-consents
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "items": [
    {
      "consentType": "ACTIVITY_CONTEXT",
      "enabled": true
    },
    {
      "consentType": "MANAGED_FOLDER",
      "enabled": false
    }
  ]
}
