spring:
  config:
    activate:
      on-profile: secret

  datasource:
    username: CHANGE_ME
    password: CHANGE_ME

jwt:
  secret: CHANGE_ME_AT_LEAST_32_BYTES_RANDOM_STRING
  access-token-expire-ms: 3600000
  refresh-token-expire-ms: 1209600000

aws:
  region: ap-northeast-2
  access-key: CHANGE_ME
  secret-key: CHANGE_ME
  s3:
    bucket: CHANGE_ME
  bedrock:
    chat-model: anthropic.claude-haiku-4-5
    embedding-model: amazon.titan-embed-text-v2:0

livekit:
  api-key: CHANGE_ME
  api-secret: CHANGE_ME
  server-url: CHANGE_ME

google:
  oauth:
    client-id: CHANGE_ME
    client-secret: CHANGE_ME
    redirect-uri: http://localhost:3000/auth/callback
  calendar:
    client-id: CHANGE_ME
    client-secret: CHANGE_ME
