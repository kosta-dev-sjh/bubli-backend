# Copy this file to application-secret.yml and fill real values.
# application-secret.yml is ignored by git and must never be committed.

google:
  oauth:
    client-id: ${GOOGLE_OAUTH_CLIENT_ID:replace-with-google-client-id}
    client-secret: ${GOOGLE_OAUTH_CLIENT_SECRET:replace-with-google-client-secret}
    redirect-uri: ${GOOGLE_OAUTH_REDIRECT_URI:http://localhost:3791/auth/callback}
  calendar:
    client-id: ${GOOGLE_CALENDAR_CLIENT_ID:${google.oauth.client-id}}
    client-secret: ${GOOGLE_CALENDAR_CLIENT_SECRET:${google.oauth.client-secret}}
    redirect-uri: ${GOOGLE_CALENDAR_REDIRECT_URI:http://localhost:3791/calendar/google/callback}

jwt:
  secret: ${JWT_SECRET:replace-with-at-least-32-byte-secret}

livekit:
  api-key: ${LIVEKIT_API_KEY:replace-with-livekit-api-key}
  api-secret: ${LIVEKIT_API_SECRET:replace-with-livekit-api-secret}
  server-url: ${LIVEKIT_SERVER_URL:wss://replace-with-livekit-server-url}
